# editor-web (Vite SPA) — copy to .env (gitignored). Only VITE_* vars are exposed to the client.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Optional: in production, point the SPA at the deployed API worker origin.
# Leave unset in dev — the Vite dev server proxies /api/* to the local worker on :8787.
VITE_API_BASE_URL=
