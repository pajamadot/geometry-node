# api worker secrets — copy to .dev.vars (gitignored) for local `wrangler dev`.
# In production set these via `wrangler secret put <NAME> --env production`.
OPENROUTER_API_KEY=sk-or-xxx
CLERK_SECRET_KEY=sk_test_xxx
# CLERK_PUBLISHABLE_KEY and ALLOWED_ORIGIN are non-secret and live in wrangler.toml [vars].
